{
    "files.associations": {
        "*.vue": "vue",
        "*.pug": "pug"
    },
    "editor.semanticHighlighting.enabled": true,
    "editor.foldingStrategy": "auto",
    "editor.language.colorizedBracketPairs": [],
    "[vue]": {
        "editor.foldingStrategy": "indentation"
    },
    "[pug]": {
        "editor.foldingStrategy": "indentation"
    }
}